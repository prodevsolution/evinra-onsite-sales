# ─────────────────────────────────────────────────────
#  Evinra Box Office — Square Configuration
#  Get these from https://developer.squareup.com/apps
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# "sandbox" or "production"
SQUARE_ENV=sandbox

# Sandbox access token  →  Developer Dashboard → Sandbox → Access token
# Starts with: sandbox-sq0atb-...
SQUARE_ACCESS_TOKEN=

# Location ID  →  Developer Dashboard → Sandbox → Locations → Location ID
SQUARE_LOCATION_ID=

# Local server port
PORT=5501
